# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_DB_URL=   # connection string direta do Postgres (Project Settings > Database > Connection string > URI), só para rodar DDL/migrations

# Extraction backend
EXTRACTOR_PROVIDER=ollama   # ollama | claude
EXTRACTOR_API_URL=http://localhost:8000
OLLAMA_MODEL=minicpm-v   # minicpm-v (~5.5GB) testado; qwen2.5-vl é a outra opção do roadmap (não testado ainda)

# Claude API (optional, only if EXTRACTOR_PROVIDER=claude)
ANTHROPIC_API_KEY=
